# Copy to .env and adjust. All values are read by app/config.py.

# Root address used to build every QR code and absolute link.
# Must be reachable from phones on the makerspace LAN.
# Examples: http://192.168.1.50:8080  |  http://lantern.local  |  https://lantern.makerspace.org
BASE_URL=http://localhost:8080

# Where the runtime data lives (content git repo, sqlite db, uploaded logo).
# In Docker this is the mounted volume.
DATA_DIR=/data

# Shared "Space PIN" required to edit/create sheets (soft gate, not auth).
EDIT_PIN=changeme

# Set to 0 to disable the PIN gate entirely (fully open wiki).
PIN_ENABLED=1

# Project source repo, linked in the printed sheet footer.
REPO_URL=https://github.com/sliptonic/lantern

# Seed a couple of sample sheets on first run (when the store is empty).
# Set to 0 for a clean, empty install.
SEED_SAMPLES=1

# Server bind (inside the container).
HOST=0.0.0.0
PORT=8080
