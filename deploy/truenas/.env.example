# Copy to .env (next to docker-compose.yml) and fill in for your TrueNAS box.

# Host dataset path that will hold ALL Lantern data (mounted at /data).
# Create this dataset in the TrueNAS UI first. Snapshots of it back up everything.
LANTERN_DATA=/mnt/tank/apps/lantern

# The LAN address phones will reach. Use the server's reserved/static IP.
BASE_URL=http://192.168.1.50:8080

# Real shared Space PIN, posted on the wall (required for editing).
EDIT_PIN=change-this-pin

# Paper size for printed sheets: letter (US) or a4 (metric).
PAGE_SIZE=letter

# Host port to publish.
PORT=8080
